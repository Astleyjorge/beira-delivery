# Copy this file to .env and fill in the values before running the server.
# Never commit .env to version control.

PORT=3000

# Secret key used to sign JWT tokens.
# Use a long random string in production — e.g. generate one with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_secret_here

# M-Pesa Mozambique API credentials
# Obtain from https://developer.mpesa.vm.co.mz after creating an app
MPESA_API_KEY=your_api_key_here
MPESA_PUBLIC_KEY=your_public_key_here
MPESA_SERVICE_PROVIDER_CODE=171717
MPESA_API_HOST=api.sandbox.vm.co.mz
MPESA_ORIGIN=developer.mpesa.vm.co.mz
